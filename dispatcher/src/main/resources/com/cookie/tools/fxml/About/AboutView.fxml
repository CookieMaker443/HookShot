<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" styleClass="about-background" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cookie.tools.controllers.About.AboutController">

    <Label styleClass="about-title" text="HookShot" />
    <Label styleClass="about-version" text="v1.0.0" />

    <Separator />

    <Label styleClass="about-description" text="%about.description" textAlignment="CENTER" wrapText="true" />

    <Separator />

    <Label styleClass="about-author" text="CookieMaker443" />
    <Hyperlink onAction="#onGithubClick" styleClass="about-link" text="github.com/CookieMaker443/HookShot" />

    <Separator />

    <Button onAction="#onCoffeeClick" styleClass="secondary-button" text="☕ Buy me a coffee" />

    <Separator />

    <Label styleClass="about-license" text="%about.license" />

</VBox>
